opus-4', 'claude-haiku-3-5'];\n  return {\n    vaultPath:      e.OBSIDIAN_VAULT_PATH,\n    apiKey:         e.ANTHROPIC_API_KEY,\n    model:          VM.includes(e.CLAUDE_MODEL) ? e.CLAUDE_MODEL : 'claude-sonnet-4-6',\n    maxChars:       Math.min(Math.max(parseInt(e.SOURCE_TEXT_MAX_CHARS) || 60000, 1000), 200000),\n    maxTokens:      Math.min(Math.max(parseInt(e.CLAUDE_MAX_TOKENS) || 8192, 1000), 128000),\n    maxRetries:     Math.min(Math.max(parseInt(e.CLAUDE_MAX_RETRIES) || 4, 1), 10),\n    cacheMaxAge:    Math.min(Math.max(parseInt(e.SNAPSHOT_CACHE_MINUTES) || 30, 1), 1440) * 60000,\n    maxVersions:    Math.min(Math.max(parseInt(e.MAX_NOTE_VERSIONS) || 5, 1), 20),\n    councilEnabled: (e.COUNCIL_DEBATE_ENABLED || 'false').toLowerCase() === 'true',\n    humanReview:    (e.HUMAN_REVIEW_ENABLED || 'false').toLowerCase() === 'true',\n    janitorWebhook: e.JANITOR_WEBHOOK_URL || ''\n  };\n}\n// ── End Shared Utilities ───────────────────────────────────────────────────\n\nconst https = require('https');\nconst cfg = getConfig();\nconst { apiKey, model, maxRetries } = cfg;\nconst data = $input.item.json;\nconst batchId = data._batch_id || 'unknown';\n\nconst rawSummary = typeof data.council_debate_summary === 'string' ? data.council_debate_summary : '[no summary]';\n// Sanitize user data before injecting into prompt\nconst sanitisedSummary = rawSummary.replace(/[\\u0000-\\u001F\\u007F]/g, ' ').substring(0, 8000);\n\nconst SYSTEM = `You are a rigorous intellectual Devil's Advocate. Your role is to critically examine knowledge claims and identify weaknesses, biases, or unsupported assertions. Be precise, evidence-based, and constructive.`;\nconst USER = `<summary-to-critique>\\n${sanitisedSummary}\\n</summary-to-critique>\\n\\nProvide a structured critique in under 300 words. Identify the 2-3 most questionable claims.`;\n\nfunction callClaude(attempt) {\n  return new Promise((resolve, reject) => {\n    const payload = JSON.stringify({ model, max_tokens: 1024, system: 