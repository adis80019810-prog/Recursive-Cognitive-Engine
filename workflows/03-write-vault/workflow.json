      "parameters": {
        "jsCode": "// ── RCE Shared Utilities v3 (inlined – no eval()) ─────────────────────────\nconst _fs = require('fs'), _path = require('path');\n\nfunction sanitizeFilename(raw) {\n  if (!raw || typeof raw !== 'string') throw new Error('sanitizeFilename: invalid input');\n  const base = _path.basename(raw.replace(/\\\\/g, '/'));\n  const out = base.replace(/[<>:\"\\/\\\\|?*\\x00-\\x1f]/g, '-')\n    .replace(/\\.{2,}/g, '-').replace(/-{2,}/g, '-').trim();\n  if (!out || out === '-' || out.replace(/\\.md$/, '').length === 0)\n    throw new Error('sanitizeFilename: unusable for \"' + raw + '\"');\n  return out;\n}\n\nfunction validateVaultPath(targetPath, vaultRoot) {\n  const res = _path.resolve(targetPath), root = _path.resolve(vaultRoot);\n  if (!res.startsWith(root + _path.sep) && res !== root)\n    throw new Error('SECURITY: path traversal blocked: \"' + targetPath + '\"');\n  return res;\n}\n\nfunction safeTruncate(str, maxBytes) {\n  if (typeof str !== 'string') return '';\n  if (Buffer.byteLength(str, 'utf8') <= maxBytes) return str;\n  let lo = 0, hi = str.length;\n  while (lo < hi) {\n    const mid = Math.ceil((lo + hi) / 2);\n    Buffer.byteLength(str.slice(0, mid), 'utf8') <= maxBytes ? (lo = mid) : (hi = mid - 1);\n  }\n  return str.slice(0, lo);\n}\n\nfunction slog(vaultPath, node, level, message, batchId, metrics) {\n  try {\n    const e = JSON.stringify({\n      ts: new Date().toISOString(), node, level,\n      batchId: batchId || 'unknown', message,\n      ...(metrics ? { metrics } : {})\n    });\n    _fs.appendFileSync(_path.join(vaultPath, '04_Meta', 'structured.log'), e + '\\n');\n  } catch (_) {}\n}\n\nfunction getConfig() {\n  const e = process.env;\n  if (!e.OBSIDIAN_VAULT_PATH) throw new Error('OBSIDIAN_VAULT_PATH is not set');\n  if (!e.ANTHROPIC_API_KEY || !e.ANTHROPIC_API_KEY.startsWith('sk-') || e.ANTHROPIC_API_KEY.length < 20)\n    throw new Error('ANTHROPIC_API_KEY is missing or invalid');\n  const VM = ['claude-sonnet-4-6', 'claude-opus-4', 'claude-haiku-3-5'];\n  return {\n    vaultPath:      e.OBSIDIAN_VAULT_PATH,\n    apiKey:         e.ANTHROPIC_API_KEY,\n    model:          VM.includes(e.CLAUDE_MODEL) ? e.CLAUDE_MODEL : 'claude-sonnet-4-6',\n    maxChars:       Math.min(Math.max(parseInt(e.SOURCE_TEXT_MAX_CHARS) || 60000, 1000), 200000),\n    maxTokens:      Math.min(Math.max(parseInt(e.CLAUDE_MAX_TOKENS) || 8192, 1000), 128000),\n    maxRetries:     Math.min(Math.max(parseInt(e.CLAUDE_MAX_RETRIES) || 4, 1), 10),\n    cacheMaxAge:    Math.min(Math.max(parseInt(e.SNAPSHOT_CACHE_MINUTES) || 30, 1), 1440) * 60000,\n    maxVersions:    Math.min(Math.max(parseInt(e.MAX_NOTE_VERSIONS) || 5, 1), 20),\n    councilEnabled: (e.COUNCIL_DEBATE_ENABLED || 'false').toLowerCase() === 'true',\n    humanReview:    (e.HUMAN_REVIEW_ENABLED || 'false').toLowerCase() === 'true',\n    janitorWebhook: e.JANITOR_WEBHOOK_URL || ''\n  };\n}\n// ── End Shared Utilities ───────────────────────────────────────────────────\n\nconst crypto = require('crypto');\nconst cfg = getConfig();\nconst { vaultPath, maxVersions } = cfg;\nconst resolvedVault = _path.resolve(vaultPath);\nconst note = $input.item.json;\nconst batchId = note._batch_id || 'unknown';\nconst t0 = Date.now();\n\nconst safeFilename = sanitizeFilename(note.filename || 'untitled.md');\nconst rawFolder = (note.folder || '01_Wiki_Nodes').replace(/\\.\\.[\\/\\\\]/g, '').replace(/^[\\/\\\\]+/, '');\nconst targetFolder = validateVaultPath(_path.join(resolvedVault, rawFolder), resolvedVault);\n_fs.mkdirSync(targetFolder, { recursive: true });\nconst fullPath = _path.join(targetFolder, safeFilename);\nvalidateVaultPath(fullPath, resolvedVault);\n\nconst newContent = note.content || '';\nconst newHash = crypto.createHash('sha256').update(newContent, 'utf8').digest('hex').substring(0, 16);\n\nlet action = 'created';\n\n// Dedup: fuzzy slug match against existing files\nfunction extractSlug(fn) { return fn.replace(/^\\d+_/, '').replace(/\\.md$/, '').replace(/[-_]/g, ' ').toLowerCase(); }\nconst newSlug = extractSlug(safeFilename);\n\nif (_fs.existsSync(fullPath)) {\n  // Exact match — version and overwrite\n  const existing = _fs.readFileSync(fullPath, 'utf8');\n  const existHash = crypto.createHash('sha256').update(existing, 'utf8').digest('hex').substring(0, 16);\n  if (existHash === newHash) {\n    slog(vaultPath, 'Write-Note', 'info', 'Identical content — skipped', batchId, { file: safeFilename });\n    return { json: { ...note, _write_action: 'skipped_identical', _write_path: fullPath }};\n  }\n  // Version the old file\n  const versDir = _path.join(targetFolder, '.versions');\n  _fs.mkdirSync(versDir, { recursive: true });\n  const ts = new Date().toISOString().replace(/[:.]/g, '-').substring(0, 19);\n  _fs.writeFileSync(_path.join(versDir, `${safeFilename}.${ts}.bak`), existing, 'utf8');\n  // Prune old versions\n  const baks = _fs.readdirSync(versDir).filter(f => f.startsWith(safeFilename)).sort();\n  if (baks.length > maxVersions)\n    baks.slice(0, baks.length - maxVersions).forEach(f => { try { _fs.unlinkSync(_path.join(versDir, f)); } catch (_) {} });\n  action = 'versioned';\n} else {\n  // Check fuzzy duplicates (70% word overlap threshold with minimum note count guard)\n  try {\n    const parentContents = _fs.readdirSync(targetFolder).filter(f => f.endsWith('.md'));\n    const nW = new Set(newSlug.split(' ').filter(w => w.length > 3));\n    if (nW.size > 2) { // Only do fuzzy match when slug has enough words\n      for (const ef of parentContents) {\n        const eSlug = extractSlug(ef);\n        const eW = new Set(eSlug.split(' ').filter(w => w.length > 3));\n        if (eW.size < 2) continue;\n        const overlap = [...nW].filter(w => eW.has(w)).length / Math.max(nW.size, eW.size);\n        if (overlap >= 0.75) { // Raised threshold to reduce false positives\n          slog(vaultPath, 'Write-Note', 'warn', 'Fuzzy duplicate detected: ' + ef, batchId, { overlap });\n          action = 'fuzzy_duplicate_skipped';\n          return { json: { ...note, _write_action: action, _duplicate_of: ef }};\n        }\n      }\n    }\n  } catch (_) {}\n}\n\n// Atomic write: write to .tmp then rename\nconst tmpPath = fullPath + '.tmp';\n_fs.writeFileSync(tmpPath, newContent, 'utf8');\n_fs.renameSync(tmpPath, fullPath); // Atomic on POSIX\n\nconst elapsed = Date.now() - t0;\nslog(vaultPath, 'Write-Note', 'info', action + ': ' + safeFilename, batchId, { elapsed_ms: elapsed });\nreturn { json: { ...note, _write_action: action, _write_path: fullPath, _content_hash: newHash }};\n"
