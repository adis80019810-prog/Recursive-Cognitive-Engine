      "parameters": {
        "jsCode": "// ── RCE Shared Utilities v3 (inlined – no eval()) ─────────────────────────\nconst _fs = require('fs'), _path = require('path');\n\nfunction sanitizeFilename(raw) {\n  if (!raw || typeof raw !== 'string') throw new Error('sanitizeFilename: invalid input');\n  const base = _path.basename(raw.replace(/\\\\/g, '/'));\n  const out = base.replace(/[<>:\"\\/\\\\|?*\\x00-\\x1f]/g, '-')\n    .replace(/\\.{2,}/g, '-').replace(/-{2,}/g, '-').trim();\n  if (!out || out === '-' || out.replace(/\\.md$/, '').length === 0)\n    throw new Error('sanitizeFilename: unusable for \"' + raw + '\"');\n  return out;\n}\n\nfunction validateVaultPath(targetPath, vaultRoot) {\n  const res = _path.resolve(targetPath), root = _path.resolve(vaultRoot);\n  if (!res.startsWith(root + _path.sep) && res !== root)\n    throw new Error('SECURITY: path traversal blocked: \"' + targetPath + '\"');\n  return res;\n}\n\nfunction safeTruncate(str, maxBytes) {\n  if (typeof str !== 'string') return '';\n  if (Buffer.byteLength(str, 'utf8') <= maxBytes) return str;\n  let lo = 0, hi = str.length;\n  while (lo < hi) {\n    const mid = Math.ceil((lo + hi) / 2);\n    Buffer.byteLength(str.slice(0, mid), 'utf8') <= maxBytes ? (lo = mid) : (hi = mid - 1);\n  }\n  return str.slice(0, lo);\n}\n\nfunction slog(vaultPath, node, level, message, batchId, metrics) {\n  try {\n    const e = JSON.stringify({\n      ts: new Date().toISOString(), node, level,\n      batchId: batchId || 'unknown', message,\n      ...(metrics ? { metrics } : {})\n    });\n    _fs.appendFileSync(_path.join(vaultPath, '04_Meta', 'structured.log'), e + '\\n');\n  } catch (_) {}\n}\n\nfunction getConfig() {\n  const e = process.env;\n  if (!e.OBSIDIAN_VAULT_PATH) throw new Error('OBSIDIAN_VAULT_PATH is not set');\n  if (!e.ANTHROPIC_API_KEY || !e.ANTHROPIC_API_KEY.startsWith('sk-') || e.ANTHROPIC_API_KEY.length < 20)\n    throw new Error('ANTHROPIC_API_KEY is missing or invalid');\n  const VM = ['claude-sonnet-4-6', 'claude-opus-4', 'claude-haiku-3-5'];\n  return {\n    vaultPath:      e.OBSIDIAN_VAULT_PATH,\n    apiKey:         e.ANTHROPIC_API_KEY,\n    model:          VM.includes(e.CLAUDE_MODEL) ? e.CLAUDE_MODEL : 'claude-sonnet-4-6',\n    maxChars:       Math.min(Math.max(parseInt(e.SOURCE_TEXT_MAX_CHARS) || 60000, 1000), 200000),\n    maxTokens:      Math.min(Math.max(parseInt(e.CLAUDE_MAX_TOKENS) || 8192, 1000), 128000),\n    maxRetries:     Math.min(Math.max(parseInt(e.CLAUDE_MAX_RETRIES) || 4, 1), 10),\n    cacheMaxAge:    Math.min(Math.max(parseInt(e.SNAPSHOT_CACHE_MINUTES) || 30, 1), 1440) * 60000,\n    maxVersions:    Math.min(Math.max(parseInt(e.MAX_NOTE_VERSIONS) || 5, 1), 20),\n    councilEnabled: (e.COUNCIL_DEBATE_ENABLED || 'false').toLowerCase() === 'true',\n    humanReview:    (e.HUMAN_REVIEW_ENABLED || 'false').toLowerCase() === 'true',\n    janitorWebhook: e.JANITOR_WEBHOOK_URL || ''\n  };\n}\n// ── End Shared Utilities ───────────────────────────────────────────────────\n\nconst https = require('https');\nconst cfg = getConfig();\nconst { vaultPath, apiKey, model, maxTokens, maxRetries } = cfg;\nconst data = $input.item.json;\nconst batchId = data._batch_id || 'unknown';\nconst text = data.text || '';\nconst snapshot = data._vault_snapshot || [];\n\nconst SYSTEM_PROMPT = `You are the Recursive Cognitive Engine (RCE), an expert knowledge-management AI for Obsidian second-brain systems.\n\nTASK: Decompose the source document into 8-12 interconnected atomic Zettelkasten notes.\n\nRETURN: One valid JSON object only — no prose, no markdown fences, no explanation.\n\nJSON SCHEMA (all fields required):\n{\n  \"batch_id\": \"<ISO timestamp>\",\n  \"source_title\": \"<title string>\",\n  \"council_debate_summary\": \"<2-3 sentence overview>\",\n  \"notes\": [\n    {\n      \"filename\": \"01_Slug.md\",\n      \"folder\": \"01_Wiki_Nodes\",\n      \"title\": \"<note title>\",\n      \"content\": \"<full markdown note content with frontmatter>\",\n      \"links\": [\"[[Other Note]]\"],\n      \"tags\": [\"tag1\",\"tag2\"]\n    }\n  ],\n  \"lesson_cemetery_candidates\": [],\n  \"experiment_24h\": { \"title\": \"\", \"hypothesis\": \"\", \"steps\": [], \"success_metric\": \"\" }\n}\n\nEXISTING VAULT NOTES (avoid duplicates, prefer linking):\n${JSON.stringify(snapshot.slice(0, 200).map(n => n.rel), null, 0)}`;\n\n// Construct messages (system = instructions, user = data only — FIX: no dual-prompt)\nconst messages = [\n  {\n    role: 'user',\n    content: `<source-document>\\n${text}\\n</source-document>`\n  }\n];\n\nfunction callClaude(attempt) {\n  return new Promise((resolve, reject) => {\n    const payload = JSON.stringify({ model, max_tokens: maxTokens, system: SYSTEM_PROMPT, messages });\n    const opts = {\n      hostname: 'api.anthropic.com', path: '/v1/messages', method: 'POST',\n      headers: {\n        'x-api-key': apiKey, 'anthropic-version': '2023-06-01',\n        'content-type': 'application/json', 'content-length': Buffer.byteLength(payload)\n      }\n    };\n    const req = https.request(opts, res => {\n      let body = '';\n      res.on('data', d => body += d);\n      res.on('end', () => {\n        if (res.statusCode === 200) resolve(JSON.parse(body));\n        else if ([429, 529].includes(res.statusCode) && attempt < maxRetries) {\n          const wait = Math.pow(2, attempt) * 1000;\n          setTimeout(() => callClaude(attempt + 1).then(resolve).catch(reject), wait);\n        } else reject(new Error('[Decompose] Claude API error ' + res.statusCode + ': ' + body.substring(0, 200)));\n      });\n    });\n    req.on('error', reject);\n    req.write(payload);\n    req.end();\n  });\n}\n\nconst t0 = Date.now();\nconst response = await callClaude(1);\nconst duration = Date.now() - t0;\n\nslog(vaultPath, 'Decompose-Claude', 'info', 'Claude API call complete', batchId, {\n  model, duration_ms: duration,\n  input_tokens: response.usage?.input_tokens,\n  output_tokens: response.usage?.output_tokens\n});\n\nreturn { json: { ...data, ...response, _batch_id: batchId, _api_duration_ms: duration }};\n"
      }
    },
    {
      "id": "n-6a71d2f8fd22",
      "name": "Parse and Validate Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
