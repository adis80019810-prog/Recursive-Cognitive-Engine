    {
      "id": "n-80a21696ed91",
      "name": "Discard and Reject",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2260,
        320
      ],
      "parameters": {
        "jsCode": "\nconst _fs = require('fs'), _path = require('path');\nconst vaultPath = process.env.OBSIDIAN_VAULT_PATH;\nconst data = $input.item.json;\nconst previewPath = data._staging_preview_path || data.body?._staging_preview_path;\nconst sourcePath = data._source_path || data.body?._source_path || '';\nconst batchId = data._batch_safe_id || data.body?._batch_safe_id || 'unknown';\nconst lockPath = data._lock_path || data.body?._lock_path || '';\n\nif (previewPath) { try { _fs.unlinkSync(previewPath); } catch (_) {} }\nif (lockPath && _fs.existsSync(lockPath)) { try { _fs.unlinkSync(lockPath); } catch (_) {} }\n\nif (sourcePath && _fs.existsSync(sourcePath)) {\n  const rejDir = _path.join(vaultPath, '00_Inbox', '_rejected');\n  _fs.mkdirSync(rejDir, { recursive: true });\n  const base = _path.basename(sourcePath).replace(/\\.processing$/, '');\n  const ts = new Date().toISOString().replace(/[:.]/g, '-').substring(0, 19);\n  _fs.renameSync(sourcePath, _path.join(rejDir, ts + '_' + base));\n}\nreturn { json: { status: 'rejected', batch_id: batchId }};\n"
      }
    },
    {
      "id": "n-3763a48b4b5e",
      "name": "Call: RCE-03-Write-Vault",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
