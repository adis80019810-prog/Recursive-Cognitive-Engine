    {
      "id": "n-96fb6646b103",
      "name": "Write Staging Preview",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1060,
        300
      ],
      "parameters": {
        "jsCode": "\nconst _fs = require('fs'), _path = require('path');\nconst data = $input.item.json;\nconst vaultPath = process.env.OBSIDIAN_VAULT_PATH;\nconst batchId = data._batch_id || new Date().toISOString();\nconst safeId = batchId.replace(/[:.]/g, '-').substring(0, 24);\nconst stagingDir = _path.join(vaultPath, '04_Meta', '_staging');\n_fs.mkdirSync(stagingDir, { recursive: true });\n\nconst noteList = (data.notes || []).map((n, i) =>\n  `${i + 1}. \\`${n.folder}/${n.filename}\\` — ${n.title || '(no title)'}`\n).join('\\n');\n\nconst content = `---\ntitle: \"Pending Review: ${data.source_title || 'Unknown'}\"\ndate: \"${new Date().toISOString().split('T')[0]}\"\ntags: [review-pending, ai-generated]\nbatch_id: \"${batchId}\"\n---\n\n# Pending: ${data.source_title || 'Unknown'}\n\n> Batch: \\`${batchId}\\`\n${data.source_truncated ? '> ⚠️ ' + data.truncation_note + '\\n' : ''}\n## Notes to be Written (${(data.notes || []).length})\n\n${noteList}\n\n## Council Summary\n\n${(data.council_debate_summary || '_none_').substring(0, 500)}\n\n---\n*To approve: POST \\`{\"decision\":\"approve\",\"batchId\":\"${batchId}\"}\\` to the webhook.*\n*To reject: POST \\`{\"decision\":\"reject\",\"batchId\":\"${batchId}\"}\\` to the webhook.*\n`;\n\nconst previewPath = _path.join(stagingDir, `review_${safeId}.md`);\n_fs.writeFileSync(previewPath, content, 'utf8');\nreturn { json: { ...data, _staging_preview_path: previewPath, _batch_safe_id: safeId }};\n"
      }
    },
