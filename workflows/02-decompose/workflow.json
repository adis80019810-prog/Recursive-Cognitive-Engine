      "parameters": {
        "jsCode": "// ── RCE Shared Utilities v3 (inlined – no eval()) ─────────────────────────\nconst _fs = require('fs'), _path = require('path');\n\nfunction sanitizeFilename(raw) {\n  if (!raw || typeof raw !== 'string') throw new Error('sanitizeFilename: invalid input');\n  const base = _path.basename(raw.replace(/\\\\/g, '/'));\n  const out = base.replace(/[<>:\"\\/\\\\|?*\\x00-\\x1f]/g, '-')\n    .replace(/\\.{2,}/g, '-').replace(/-{2,}/g, '-').trim();\n  if (!out || out === '-' || out.replace(/\\.md$/, '').length === 0)\n    throw new Error('sanitizeFilename: unusable for \"' + raw + '\"');\n  return out;\n}\n\nfunction validateVaultPath(targetPath, vaultRoot) {\n  const res = _path.resolve(targetPath), root = _path.resolve(vaultRoot);\n  if (!res.startsWith(root + _path.sep) && res !== root)\n    throw new Error('SECURITY: path traversal blocked: \"' + targetPath + '\"');\n  return res;\n}\n\nfunction safeTruncate(str, maxBytes) {\n  if (typeof str !== 'string') return '';\n  if (Buffer.byteLength(str, 'utf8') <= maxBytes) return str;\n  let lo = 0, hi = str.length;\n  while (lo < hi) {\n    const mid = Math.ceil((lo + hi) / 2);\n    Buffer.byteLength(str.slice(0, mid), 'utf8') <= maxBytes ? (lo = mid) : (hi = mid - 1);\n  }\n  return str.slice(0, lo);\n}\n\nfunction slog(vaultPath, node, level, message, batchId, metrics) {\n  try {\n    const e = JSON.stringify({\n      ts: new Date().toISOString(), node, level,\n      batchId: batchId || 'unknown', message,\n      ...(metrics ? { metrics } : {})\n    });\n    _fs.appendFileSync(_path.join(vaultPath, '04_Meta', 'structured.log'), e + '\\n');\n  } catch (_) {}\n}\n\nfunction getConfig() {\n  const e = process.env;\n  if (!e.OBSIDIAN_VAULT_PATH) throw new Error('OBSIDIAN_VAULT_PATH is not set');\n  if (!e.ANTHROPIC_API_KEY || !e.ANTHROPIC_API_KEY.startsWith('sk-') || e.ANTHROPIC_API_KEY.length < 20)\n    throw new Error('ANTHROPIC_API_KEY is missing or invalid');\n  const VM = ['claude-sonnet-4-6', 'claude-opus-4', 'claude-haiku-3-5'];\n  return {\n    vaultPath:      e.OBSIDIAN_VAULT_PATH,\n    apiKey:         e.ANTHROPIC_API_KEY,\n    model:          VM.includes(e.CLAUDE_MODEL) ? e.CLAUDE_MODEL : 'claude-sonnet-4-6',\n    maxChars:       Math.min(Math.max(parseInt(e.SOURCE_TEXT_MAX_CHARS) || 60000, 1000), 200000),\n    maxTokens:      Math.min(Math.max(parseInt(e.CLAUDE_MAX_TOKENS) || 8192, 1000), 128000),\n    maxRetries:     Math.min(Math.max(parseInt(e.CLAUDE_MAX_RETRIES) || 4, 1), 10),\n    cacheMaxAge:    Math.min(Math.max(parseInt(e.SNAPSHOT_CACHE_MINUTES) || 30, 1), 1440) * 60000,\n    maxVersions:    Math.min(Math.max(parseInt(e.MAX_NOTE_VERSIONS) || 5, 1), 20),\n    councilEnabled: (e.COUNCIL_DEBATE_ENABLED || 'false').toLowerCase() === 'true',\n    humanReview:    (e.HUMAN_REVIEW_ENABLED || 'false').toLowerCase() === 'true',\n    janitorWebhook: e.JANITOR_WEBHOOK_URL || ''\n  };\n}\n// ── End Shared Utilities ───────────────────────────────────────────────────\n\nconst cfg = getConfig();\nconst { vaultPath, cacheMaxAge } = cfg;\nconst cacheFile = _path.join(vaultPath, '04_Meta', '.snapshot_cache.json');\nconst MAX_FILES = 10000;\nlet snapshot = null;\n\n// Use cached snapshot if fresh\ntry {\n  if (_fs.existsSync(cacheFile)) {\n    const c = JSON.parse(_fs.readFileSync(cacheFile, 'utf8'));\n    if (Date.now() - new Date(c.cached_at).getTime() < cacheMaxAge) {\n      snapshot = c.snapshot;\n    }\n  }\n} catch (_) {}\n\nif (!snapshot) {\n  // Build compact titles-only index (avoids loading full file contents)\n  function scanDir(dir, base) {\n    base = base || '';\n    let out = [];\n    if (!_fs.existsSync(dir)) return out;\n    let items;\n    try { items = _fs.readdirSync(dir); } catch (_) { return out; }\n    for (const item of items) {\n      const full = _path.join(dir, item), rel = _path.join(base, item);\n      let stat;\n      try { stat = _fs.statSync(full); } catch (_) { continue; }\n      if (stat.isDirectory() && !item.startsWith('.') && !item.startsWith('_'))\n        out = out.concat(scanDir(full, rel));\n      else if (item.endsWith('.md') && !item.startsWith('_'))\n        out.push({ rel, slug: item.replace(/\\.md$/, '').replace(/[_-]+/g, ' ').toLowerCase() });\n    }\n    return out;\n  }\n  snapshot = scanDir(vaultPath).slice(0, MAX_FILES);\n  try {\n    _fs.mkdirSync(_path.dirname(cacheFile), { recursive: true });\n    _fs.writeFileSync(cacheFile, JSON.stringify({ cached_at: new Date().toISOString(), snapshot }));\n  } catch (_) {}\n}\n\nreturn { json: { ...$input.item.json, _vault_snapshot: snapshot, _snapshot_size: snapshot.length }};\n"
      }
    },
    {
      "id": "n-48f23637be49",
      "name": "Claude: Decompose Source",
      "type": "n8n-nodes-base.code",
