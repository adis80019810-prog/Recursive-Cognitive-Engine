# Required
OBSIDIAN_VAULT_PATH=/absolute/path/to/your/obsidian/vault
ANTHROPIC_API_KEY=sk-ant-...

# Optional – Recommended
CLAUDE_MODEL=claude-opus-4-72
MASTER_ARCHITECT_PROMPT_PATH=/path/to/prompt.txt

# Optional – Behaviour Tuning
HUMAN_REVIEW_ENABLED=false
SNAPSHOT_CACHE_MINUTES=5
SOURCE_TEXT_MAX_CHARS=60000
MAX_NOTE_VERSIONS=5
JANITOR_STALE_DAYS=90
SEMANTIC_SIM_THRESHOLD=0.72

# Optional – Webhooks
JANITOR_WEBHOOK_URL=https://your-webhook-url
COMPLETION_WEBHOOK_URL=https://your-completion-webhoo
